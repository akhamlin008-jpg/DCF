# NVIDIA-flavored dark theme. The CSS injected in App.py builds on top of this.
[theme]
base = "dark"
primaryColor = "#76B900"          # NVIDIA green
backgroundColor = "#0A0A0A"
secondaryBackgroundColor = "#111313"
textColor = "#EAEAEA"
font = "sans serif"

[server]
headless = true

[browser]
gatherUsageStats = false
